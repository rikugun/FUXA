# --- STAGE 1: Angular Client Builder ---
FROM node:22-bookworm AS client-builder

WORKDIR /usr/src/app/client
COPY client/package*.json ./
RUN npm install --no-audit --no-fund
COPY client/ ./
RUN npm run build -- --configuration production

# --- STAGE 2: Server & Native Dependencies Builder (Alpine) ---
FROM node:22-alpine AS server-builder
ARG NODE_SNAP=false
ARG USE_ODBC=false

# Alpine build tools for native modules (sqlite3, serialport)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    sqlite-dev \
    $( [ "$USE_ODBC" = "true" ] && echo "unixodbc-dev" )

WORKDIR /usr/src/app/FUXA/server
COPY server/package*.json ./
RUN npm install --no-audit --no-fund && \
    npm prune --production

# Optional: snap7
RUN if [ "$NODE_SNAP" = "true" ]; then npm install node-snap7; fi

# Rebuild sqlite3 from source for Alpine/musl
RUN npm install --build-from-source sqlite3

# Optional: odbc npm package
RUN if [ "$USE_ODBC" = "true" ]; then npm install odbc; fi

# Copy server source & build TypeScript
COPY server/ ./
RUN rm -rf test
RUN npm run build

# --- STAGE 3: Minimal Runner (Alpine) ---
FROM node:22-alpine
ARG USE_ODBC=false

RUN apk add --no-cache sqlite-libs

# Install minimal ODBC runtime when enabled
RUN if [ "$USE_ODBC" = "true" ]; then \
        apk add --no-cache unixodbc freetds; \
    fi

WORKDIR /usr/src/app/FUXA

# Copy server (includes node_modules)
COPY --from=server-builder /usr/src/app/FUXA/server ./server

# Copy client dist
COPY --from=client-builder /usr/src/app/client/dist ./client/dist

# Conditional ODBC config
COPY odbc/odbcinst.ini ./odbc/odbcinst.ini
RUN if [ "$USE_ODBC" = "true" ]; then \
        cp odbc/odbcinst.ini /etc/odbcinst.ini; \
    fi

# Copy node-red custom nodes
COPY node-red/ ./node-red/

# Cleanup unnecessary files in production
RUN rm -rf ./server/test 

WORKDIR /usr/src/app/FUXA/server

ENV NODE_ENV=production
EXPOSE 1881
CMD [ "node", "main.js" ]
